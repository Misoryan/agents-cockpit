# Login credentials.
# Copy this file to auth.txt and replace the password before exposing the app.
# Format: username:credential
#
# Plain text (simple, compatible):
#   claude:your-strong-password
#
# PBKDF2 hash (recommended):
#   claude:$pbkdf2$120000$<salt_b64>$<hash_b64>
# Generate a hash with:
#   python -c "import common; print(common.hash_password('your-password'))"
claude:change-me-to-a-strong-password
