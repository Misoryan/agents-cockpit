# Agents Cockpit configuration (Codex/Claude web-rendered sessions).
# Copy this file to config.ini and restart the service. Missing keys use defaults.

[server]
# Browser-facing host/port.
host = 0.0.0.0
port = 7682

# Optional HTTPS for browser access. Leave disabled for trusted LAN HTTP.
use_https = 0
cert_cn = agents-cockpit
cert_file =
key_file =
# Optional extra plain HTTP port when use_https=1; 0 disables it.
http_port = 0

[manager]
# Local-only manager port; 0 = server.port + 1000.
port = 0
heartbeat = 2
heartbeat_grace = 3

[approval]
# 1 = pass --dangerously-skip-permissions to Claude; 0 = use web approval gates.
auto_approve = 1

[binaries]
# Leave empty for auto-detect, or set an absolute path to a CLI shim.
claude =
codex =

[paths]
# Login credential file, relative to this directory unless absolute.
auth_file = auth.txt
# Leave empty for ~/.claude.
claude_home =

[ccswitch]
# Optional read-only CC Switch usage database.
db =
usage_ttl = 15
balance_ttl = 300

[limits]
buf_cap = 262144
# Max lines to scan per Claude transcript when listing history.
claude_scan_cap = 6000

[detect]
idle_debounce = 8
plan_threshold = 3

[notify]
enabled = 0
telegram_token =
telegram_chat_id =
bark_key =
webhook_url =
webhook_secret =
events = confirm,done
min_interval = 30

[security]
session_ttl = 86400
max_fail = 5
lockout_secs = 300
# Set to 1 only when the browser talks to this app over HTTPS.
cookie_secure = 0
