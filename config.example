# Agents Cockpit configuration (Codex/Claude web-rendered sessions).
# Copy this file to config.ini and restart the service. Missing keys use defaults.

[server]
# Browser-facing host/port. For tunneled/public access prefer host=127.0.0.1
# behind HTTPS/VPN/reverse proxy instead of exposing this port directly.
host = 0.0.0.0
port = 7682

# Optional HTTPS for browser access. Enable for non-local browser access and
# pair it with [security] cookie_secure=1.
use_https = 0
cert_cn = agents-cockpit
cert_file =
key_file =
# Optional extra plain HTTP port when use_https=1; 0 disables it.
http_port = 0

[manager]
# Local-only manager port; 0 = server.port + 1000.
port = 0
heartbeat = 2
heartbeat_grace = 3

[approval]
# 1 = auto-approve dangerous operations; 0 = use web approval gates.
# Set 0 for shared machines, tunnels, or any hardened deployment.
auto_approve = 1

[binaries]
# Leave empty for auto-detect, or set an absolute path to a CLI shim.
claude =
codex =

[paths]
# Login credential file, relative to this directory unless absolute.
auth_file = auth.txt
# Leave empty for ~/.claude.
claude_home =

[users]
# Local per-user data root, relative to this directory unless absolute.
data_dir = .agent-cockpit/users
# Default workspace created for each login user. Use {user} or {uid}.
default_workspace_root = .agent-cockpit/users/{uid}/workspace
# 1 = compatibility mode, allow any local path; set 0 to restrict to workspace
# roots. Hardened deployments should use 0 and configure workspace_roots per user.
allow_unconfigured_paths = 1
# 1 = first auth.txt user keeps the normal Codex/Claude homes; other users use per-user homes.
# Set 0 when multiple people share this service and should not share CLI state.
primary_user_uses_default_homes = 1

[ccswitch]
# Optional read-only CC Switch usage database.
db =
usage_ttl = 15
balance_ttl = 300

[limits]
buf_cap = 262144
# Max lines to scan per Claude transcript when listing history.
claude_scan_cap = 6000

[detect]
idle_debounce = 8
plan_threshold = 3

[codex_dynamic_tools]
# Optional `item/tool/call` passthrough allowlist.
# Left side: dynamic tool key (`namespace.tool`, `namespace.*`, or `tool`).
# Right side: MCP target (`mcp:<server>/<tool>`). `{tool}` is replaced by the
# requested dynamic tool name for namespace wildcard mappings.
# Example:
# browser.* = mcp:browser/{tool}
# docs.search = mcp:docs/search

[notify]
enabled = 0
telegram_token =
telegram_chat_id =
bark_key =
webhook_url =
webhook_secret =
events = confirm,done
min_interval = 30
# Windows native desktop toast (Action Center). 1 = also pop a local toast on the
# machine running the service (Windows only; silent no-op elsewhere). Shares the
# same enabled/events/min_interval gate above.
desktop_toast = 0

[security]
session_ttl = 86400
max_fail = 5
lockout_secs = 300
# Set to 1 when the browser talks to this app over HTTPS. Keep 0 only for local HTTP.
cookie_secure = 0
# 1 = reject browser POST and WebSocket requests whose Origin/Referer does not
# match Host/X-Forwarded-Host or [security] allowed_origins. Internal local
# Authorization requests bypass this check.
csrf_origin_check = 1
# Compatibility mode for older clients/tools that omit both Origin and Referer.
# Hardened tunnel/reverse-proxy deployments should set this to 0.
csrf_allow_missing_origin = 1
# Optional comma/semicolon-separated extra origins, e.g.
# https://agents.example.com, https://phone-tunnel.example.com
allowed_origins =
